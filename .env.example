# Q-Alpha — secrets template. Copy to `.env` (gitignored) and fill in.
# Kite Connect (Zerodha) app credentials — https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Minted daily by `python -m qalpha.live.auth`; Kite access tokens expire ~6am IST next day.
KITE_ACCESS_TOKEN=
# Dashboard gate — required when the dashboard is hosted (public URL). Empty = open (local dev only).
APP_PASSWORD=
