# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Data (large; regenerated by ingest) — keep the dirs via .gitkeep, ignore contents
data/historical/*
data/fundamentals/*
data/universes/*
# point-in-time membership = small reference data; track it (the pipeline/CI needs it)
!data/universes/*.csv
data/bhavcopy/*
!data/**/.gitkeep
!data/**/README.md
# data/paper/ (the notional paper book + track record) is TRACKED on purpose — no secrets, and the
# daily pipeline commits it as the durable record.
# Personal discretionary IPO/satellite positions — account-specific, keep out of the public repo.
data/satellite.json

# Broker exports — contain PAN / client-id / name PII; never commit (resume repo is public).
# The crit-4 reconciliation reads these locally; tests use a hermetic synthetic fixture instead.
data/tradebook-*.csv
data/taxpnl-*
data/*.jpeg
data/*.jpg
# Generated reconciliation report echoes the real client-id — keep it local (it's regenerable).
reports/crit4_reconciliation.md

# Reports
reports/*.html
reports/*.png

# Secrets — never commit broker creds (Kite api_key/secret) or minted sessions
.env
*.env
!.env.example
secrets/
.kite_session.json

# Notebooks scratch
.ipynb_checkpoints/
