# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Data (large; regenerated by ingest) — keep the dirs via .gitkeep, ignore contents
data/historical/*
data/fundamentals/*
data/universes/*
# point-in-time membership = small reference data; track it (the pipeline/CI needs it)
!data/universes/*.csv
data/bhavcopy/*
!data/**/.gitkeep
!data/**/README.md
# data/paper/ (the notional paper book + track record) is TRACKED on purpose — no secrets, and the
# daily pipeline commits it as the durable record.

# Reports
reports/*.html
reports/*.png

# Secrets — never commit broker creds (Kite api_key/secret) or minted sessions
.env
*.env
!.env.example
secrets/
.kite_session.json

# Notebooks scratch
.ipynb_checkpoints/
