data/universes/*
data/bhavcopy/*
!data/**/.gitkeep
!data/**/README.md

# Reports
reports/*.html
reports/*.png

# Secrets — never commit broker creds (Kite api_key/secret)
.env
*.env
secrets/

# Notebooks scratch
.ipynb_checkpoints/
